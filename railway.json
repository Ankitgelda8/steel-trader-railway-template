{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "Postgres",
      "plugin": "postgresql"
    },
    {
      "name": "backend",
      "source": {
        "repo": "https://github.com/Ankitgelda8/steel-trader-railway-template",
        "branch": "main"
      },
      "subdirectory": "backend",
      "variables": {
        "DATABASE_URL": {
          "description": "PostgreSQL connection URL — auto-filled from the Postgres addon above",
          "value": "${{Postgres.DATABASE_URL}}"
        },
        "SECRET_KEY": {
          "description": "JWT signing secret — generate with: python -c \"import secrets; print(secrets.token_hex(32))\"",
          "required": true
        },
        "ADMIN_EMAIL": {
          "description": "Email for the auto-seeded admin account",
          "default": "admin@steel.com"
        },
        "ADMIN_PASSWORD": {
          "description": "Password for the admin account — must be changed from default",
          "required": true
        },
        "ACCESS_TOKEN_EXPIRE_MINUTES": {
          "description": "JWT token lifetime in minutes",
          "default": "1440"
        }
      }
    },
    {
      "name": "web",
      "source": {
        "repo": "https://github.com/Ankitgelda8/steel-trader-railway-template",
        "branch": "main"
      },
      "subdirectory": "web",
      "variables": {
        "VITE_API_URL": {
          "description": "Backend API URL — auto-filled from the backend service",
          "value": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api/v1"
        }
      }
    }
  ]
}
