# ─── Database ───────────────────────────────────────────────────────────────
# Default: SQLite (no setup required for dev/demo)
# Production: replace with your Railway PostgreSQL addon URL
# DATABASE_URL=postgresql://user:password@host:5432/steel_trader
DATABASE_URL=sqlite:///./steel_trader.db

# ─── Security ───────────────────────────────────────────────────────────────
# REQUIRED for production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-32-CHARACTER-STRING

# ─── Auth ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Seed Admin User (created on first startup) ─────────────────────────────
ADMIN_EMAIL=admin@steel.com
ADMIN_PASSWORD=changeme123
